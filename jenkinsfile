pipeline {
    agent any
    enviroment {
        PYTHON = "C:\\Users\\Lenovo\\AppData\\Local\\Programs\\Python\\Python314\\python.exe"

    }

    stages {
        stage("checkout code") {
            steps {
                checkout scm
            }
        }
    stages("show python version") {
        steps {
            bat "${env.PYTHON} --version"
            }
        }
    stages("run extractfile.py") {
        steps {
            but $"{env.PYTHON} extractfile.py"
            }
        }
    }
}
